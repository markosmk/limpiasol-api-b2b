{
  "name": "limpiasol-api",
  "version": "1.0.2",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node --env-file=.env build/src/index.js",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "build:with-emails": "npm run build && npm run email:build",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "dev:nodemon:src": "nodemon --watch src src/index.ts",
    "dev:nodemon": "nodemon --transpileOnly src/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=.env ./scripts/migrate.mjs",
    "db:reset": "node --env-file=.env ./scripts/db-reset.mjs",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx --env-file=.env ./scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:fresh": "pnpm run db:reset && pnpm run db:push && pnpm run db:seed",
    "email:dev": "email preview ./src/lib/emails/templates --no-open --port 55420",
    "email:check": "email check ./src/lib/emails/templates/welcome.tsx",
    "email:build": "email build ./src/lib/emails/templates --out dist/emails --minify",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "typecheck": "tsc --noEmit --skipLibCheck --isolatedModules",
    "docker:up": "docker compose -f docker-compose.yml up -d",
    "docker:down": "docker compose -f docker-compose.yml down",
    "vitest:local": "node --env-file=.env --env-file=.env.test ./node_modules/vitest/vitest.mjs",
    "test:ci": "pnpm run vitest run",
    "db:push:ci": "drizzle-kit push",
    "test": "pnpm run vitest:local run",
    "test:watch": "pnpm run vitest:local",
    "test:ui": "pnpm run vitest:local --ui",
    "test:coverage": "pnpm run vitest:local run --coverage",
    "test:e2e": "pnpm run vitest:local run --config vitest.e2e.config.ts",
    "test:push-db": "node --env-file=.env.test ./node_modules/drizzle-kit/bin.cjs push",
    "docs:bundle": "tsx scripts/bundle-openapi.ts",
    "docs:watch": "tsx watch scripts/bundle-openapi.ts",
    "docs:validate": "spectral lint docs/openapi.yaml",
    "docs:build": "pnpm docs:bundle && pnpm docs:validate | grep error | echo '--- Documentación validada correctamente ---'",
    "docs:preview": "http-server docs -p 8081"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.1.3",
    "@paralleldrive/cuid2": "^3.3.0",
    "@valibot/to-json-schema": "^1.7.0",
    "argon2": "^0.44.0",
    "close-with-grace": "^2.5.0",
    "dayjs": "^1.11.20",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "drizzle-valibot": "^0.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.10.1",
    "lru-cache": "^11.3.6",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@stoplight/spectral-cli": "^6.15.1",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "http-server": "^14.1.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "yaml": "^2.8.4"
  }
}
