{
  "name": "limpiasol-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node --env-file=.env build/src/index.js",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "build:with-emails": "npm run build && npm run email:build",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "dev:nodemon:src": "nodemon --watch src src/index.ts",
    "dev:nodemon": "nodemon --transpileOnly src/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=.env ./scripts/migrate.mjs",
    "db:seed": "tsx --env-file=.env ./scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "email:dev": "email preview ./src/lib/emails/templates --no-open --port 55420",
    "email:check": "email check ./src/lib/emails/templates/welcome.tsx",
    "email:build": "email build ./src/lib/emails/templates --out dist/emails --minify",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "typecheck": "tsc --noEmit --skipLibCheck --isolatedModules",
    "docker:up": "docker compose -f docker-compose.yml up -d",
    "docker:down": "docker compose -f docker-compose.yml down",
    "vitest:local": "node --env-file=.env ./node_modules/vitest/vitest.mjs",
    "test": "pnpm run vitest:local run",
    "test:watch": "pnpm run vitest:local",
    "test:ui": "pnpm run vitest:local --ui",
    "test:coverage": "pnpm run vitest:local run --coverage",
    "test:e2e": "pnpm run vitest:local run --config vitest.e2e.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.0.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@valibot/to-json-schema": "^1.5.0",
    "argon2": "^0.44.0",
    "close-with-grace": "^2.5.0",
    "dayjs": "^1.11.20",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "drizzle-valibot": "^0.4.2",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.10.0",
    "lru-cache": "^11.2.7",
    "mysql2": "^3.19.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/node": "^24.12.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
